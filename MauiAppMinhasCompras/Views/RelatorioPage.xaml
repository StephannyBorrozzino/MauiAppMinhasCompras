<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="MauiAppMinhasCompras.Views.RelatorioPage"
             Title="Relatório por Categoria">

    <CollectionView x:Name="relatorioView" Margin="20">
        <CollectionView.ItemTemplate>
            <DataTemplate>
                <Frame Margin="10" Padding="20">
                    <VerticalStackLayout>
                        <Label Text="{Binding Categoria}" FontAttributes="Bold" />
                        <Label Text="{Binding TotalGasto, StringFormat='Total: {0:C}'}" />
                    </VerticalStackLayout>
                </Frame>
            </DataTemplate>
        </CollectionView.ItemTemplate>
    </CollectionView>
</ContentPage>